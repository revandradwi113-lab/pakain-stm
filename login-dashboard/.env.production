# Frontend Production Environment Variables for Vercel

# Backend API URL - Change this to your Vercel backend domain after deployment
REACT_APP_API_URL=https://your-vercel-backend-domain.vercel.app

# Note: Replace "your-vercel-backend-domain" with your actual backend Vercel domain
# Example: REACT_APP_API_URL=https://toko-pakaian-api.vercel.app
